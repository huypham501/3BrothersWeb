# Database config
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# Site config
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Management API — dùng cho Asset Manager (track storage limit theo plan)
# Tạo tại: https://supabase.com/dashboard/account/tokens
# Không có biến này vẫn chạy được, nhưng limit sẽ fallback về Free plan (1 GB)
SUPABASE_MANAGEMENT_API_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CMS capture script login (password flow)
CMS_CAPTURE_LOGIN_EMAIL=content-admin@example.com
CMS_CAPTURE_LOGIN_PASSWORD=ChangeMe_StrongPassword123!

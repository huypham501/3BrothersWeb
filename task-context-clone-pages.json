  "projectRules": {
    "framework": "Next.js App Router",
    "language": "TypeScript",
    "styling": "styled-components",
    "i18n": "vi and en routes (/vi, /en)",
    "packageManager": "yarn",
    "responsive": "mobile-first with mq helper and tokenized breakpoints",
    
    "componentStructure": {
      "oneFilePerComponent": true,
      "jsxFirst": true,
      "styledComponentsBelow": true,
      "exportStyle": "named exports only",
      "example": "export function ComponentName() { ... }"
    },

    "noMagicNumbers": {
      "rule": "All spacing, typography, radius, breakpoints must come from centralized tokens",
      "exceptions": ["0", "1 (for border: 1px)"],
      "tokensPath": "src/styles/tokens.ts",
      "themePath": "src/styles/theme.ts"
    },

    "responsiveRules": {
      "approach": "mobile-first",
      "mediaQueries": "must use mq helper from src/styles/mediaQueries.ts",
      "forbidden": "hardcoded @media (max-width: 900px)",
      "breakpoints": "from tokens only"
    },

    "stylingRefactor": {
      "legacyCSSMapping": "each CSS class maps to styled component",
      "variants": "use $variant prop or separate components",
      "styleProps": "prefix with $ to avoid DOM leak (e.g., $variant, $active)",
      "responsiveRules": "place media queries next to the element they affect"
    },

    "accessibility": {
      "semantics": "correct HTML elements (button vs link, heading levels)",
      "focus": "don't remove focus styles",
      "decorative": "use aria-hidden for decorative visuals"
    },

    "seo": {
      "perRoute": "metadata export in page.tsx",
      "openGraph": true,
      "twitterCard": true,
      "canonical": true,
      "hreflang": "alternates for vi/en",
      "structuredData": "Organization, BlogPosting, JobPosting as needed"
    }
  },

